# --- Credentials & secrets (NEVER commit these) ---
.smtp_credentials
.env
.env.*
*.key
*.pem
credentials.json
secrets.json
*_credentials*
*_secret*
*.token
.git_credentials
.git_token
.github_token

# --- Excel / LibreOffice temp & lock files ---
# Microsoft Excel temp files (created while a file is open)
~$*.xlsx
~$*.xlsm
~$*.xls
~$*.docx
~$*.doc
# LibreOffice / OpenOffice lock files
.~lock.*#
# Generic Office temp patterns
*.tmp
*.temp
*.bak
*.~*

# --- OS metadata ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

